{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
	"local>tosmi-ansible/renovate-config"
	"config:best-practices"
    ],
    "timezone": "Europe/London",
    "schedule": [
        "at any time"
    ],
    "packageRules": [
	{
	    "matchDatasources": ["galaxy-collection"]
	},
	{
	    "matchDatasources": ["github-tags"],
	    "enabled": "false"
	}
    ]
}
